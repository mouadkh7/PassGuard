{
  "name": "passguard",
  "version": "6.0.0",
  "description": "PassGuard - مدير كلمات مرور مشفر بالكامل، مفتوح المصدر",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "author": "PassGuard",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.passguard.app",
    "productName": "PassGuard",
    "directories": {
      "output": "release"
    },
    "files": [
      "index.html",
      "src/**/*",
      "manifest.json",
      "sw.js",
      "electron/**/*"
    ],
    "win": {
      "target": ["nsis"],
      "icon": null
    },
    "mac": {
      "target": ["dmg"],
      "icon": null
    },
    "linux": {
      "target": ["AppImage"],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "language": "1045"
    }
  }
}
